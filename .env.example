# =============================================================================
# .env.example — template for root .env (deploy/scripts only)
# =============================================================================
# Copy to .env and fill in values. Never commit .env.
# Frontend runtime config belongs in frontend/.env.local (see that file).
# =============================================================================

# ─── Wallet / signing ─────────────────────────────────────────────────────────
PRIVATE_KEY=

# ─── RPC endpoints (deploy + scripts) ────────────────────────────────────────
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_RPC_URL_2=https://arc-testnet.drpc.org

# ─── Block explorer verification ─────────────────────────────────────────────
ARCSCAN_API_KEY=

# ─── Protocol constants (used by deploy scripts) ──────────────────────────────
USDC_ADDRESS=
TREASURY_ADDRESS=
