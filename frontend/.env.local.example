# =============================================================================
# frontend/.env.local.example — FRONTEND RUNTIME TEMPLATE
# =============================================================================
# Copy this file to frontend/.env.local and fill in your values.
# frontend/.env.local is gitignored and must NOT be committed.
# Only NEXT_PUBLIC_* variables belong here.
# Deploy secrets (PRIVATE_KEY, etc.) live in root .env (also gitignored).
# =============================================================================

# ─── Chain ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=5042002

# ─── RPC endpoints ────────────────────────────────────────────────────────────
# Primary and fallback RPC URLs for the frontend public client.
NEXT_PUBLIC_RPC_URL=https://arc-testnet.drpc.org
NEXT_PUBLIC_RPC_URL_2=https://rpc.testnet.arc.network
NEXT_PUBLIC_RPC_URL_3=https://rpc.quicknode.testnet.arc.network

# ─── WalletConnect ────────────────────────────────────────────────────────────
# WalletConnect project IDs are intentionally public (domain-restricted, not secret).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# ─── Subgraph ─────────────────────────────────────────────────────────────────
# Primary indexed-data endpoint for frontend GraphQL reads.
# Production recommendation: set this to your active Goldsky (or preferred) endpoint.
NEXT_PUBLIC_SUBGRAPH_URL=https://api.studio.thegraph.com/query/YOUR_ID/arcnslatest/v3

# Optional generic subgraph fallback endpoint.
# Queried only if NEXT_PUBLIC_SUBGRAPH_URL fails.
NEXT_PUBLIC_SUBGRAPH_FALLBACK_URL=

# Optional backward-compatible Goldsky fallback endpoint.
# Used after NEXT_PUBLIC_SUBGRAPH_FALLBACK_URL when configured and different.
NEXT_PUBLIC_GOLDSKY_SUBGRAPH_URL=
